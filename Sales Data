--SQL Wildcard Characters
/*
In Excel -?, *
In SQL _,
*/

--Pull back any Plant that starts with letter A
SELECT *
FROM [dbo].['Workplace Safety Data$']
WHERE [Plant] like 'A%';

--Pull back Incident type that starts with letter C
SELECT * 
FROM [dbo].['Workplace Safety Data$']
WHERE [Incident Type] LIKE 'C%';

--Pull back Incident type that ends with letter E
SELECT *
FROM [dbo].['Workplace Safety Data$']
WHERE [Incident Type] LIKE '%E';

--Pull back any Plant that Has  letter A
SELECT *
