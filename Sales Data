/* ALTER TABLE STATEMENTS
1. CREATE A NEW TABLE IN AN EXISTING TABLE
2.DELETE AN EXISTING COLUMN
3.CHANGE THE DATA TYPE IN COLUMN
4.UPDATE TABLE STATEMENT
5. DELETE FROM STATEMENT 
*/

-- CREATE A NEW TABLE IN AN EXISTING TABLE
ALTER TABLE [dbo].[Regional_Sales_Table]
ADD AGE INT

ALTER TABLE [dbo].[Sales Managers Record]
ADD AGE INT

ALTER TABLE [dbo].[Regional_Sales_Table]
ADD Salary DECIMAL(6,2);

--DELETE AN EXISTING COLUMN
ALTER TABLE [dbo].[Regional_Sales_Table]
DROP COLUMN Salary;

ALTER TABLE [dbo].[Regional_Sales_Table]
DROP COLUMN AGE;

--CHANGE THE DATA TYPE IN COLUMN
ALTER TABLE [dbo].[Regional_Sales_Table]
ALTER COLUMN [AGE] DECIMAL(6,2);

ALTER TABLE [dbo].[Regional_Sales_Table]
ALTER COLUMN [UnitPrice] DECIMAL (6,2);

--UPDATE TABLE STATEMENT
UPDATE [dbo].[Sales Managers Record]
SET [AGE]  = DATEDIFF(YEAR, [Date_of_Birth],GETDATE());

UPDATE [dbo].[Sales Managers Record]
SET [City] = 'Paris'
where [SalesPersonID] = 'ID004'

--DELETE FROM STATEMENT 
DELETE FROM [dbo].[Sales Managers Record]
WHERE [AGE] <= 35;


