--TO CHECK FOR DUPLICATES
--THIS WILL RETURN ONLY TABLES THAT HAS NO DUPLICATE
WITH DummyTable AS (
SELECT *, 
        ROW_NUMBER() OVER (PARTITION BY ID ORDER BY [ID]) AS Duplicate
FROM [dbo].['Food supply$']
)
SELECT *
FROM DummyTable
where Duplicate = 1;


--
WITH UNKNOWN_TABLE AS 
(
SELECT *
        ,RANK() OVER(PARTITION BY [CITY] ORDER BY QTY DESC) AS DUPLICATE
FROM [dbo].['Food supply$']
)
SELECT *
FROM UNKNOWN_TABLE
WHERE DUPLICATE = 1;

---WEEK 9
with ChimaJR_Table AS
(
SELECT [Date],[Injury Location],
        CASE
        WHEN [Incident Cost] < 100 THEN 'Cheap Cost (CC))'
        WHEN [Incident Cost] <=1000 THEN 'Affordable Cost (AC)'
        ELSE 'Expensive Cost (EC)'
        END Incident_Cost_Category
        ,CASE
        WHEN [Injury Location] = 'N/A' THEN 'TECH DRIVE'
        ELSE [Injury Location] 
        END [NEW INJURY LOCATION]
FROM [dbo].['Workplace Safety Data$']
)

SELECT COUNT(*)
FROM ChimaJR_Table
WHERE Incident_Cost_Category = 'Cheap Cost (CC))'

